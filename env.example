# ============================================================
#  Shopify MCP Server — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit your real .env file to GitHub!
# ============================================================

# ----------------------------------------------------------
# REQUIRED: Your Shopify store name
# This is the part BEFORE .myshopify.com
# Example: if your URL is my-store.myshopify.com → enter: my-store
# ----------------------------------------------------------
SHOPIFY_STORE=my-store

# ----------------------------------------------------------
# REQUIRED: Authentication
# Choose ONE of the two options below.
# ----------------------------------------------------------

# OPTION A — Recommended for most users: Static Access Token
# How to get it:
#   1. Shopify Admin → Settings → Apps and sales channels
#   2. Click "Develop apps" → Create an app
#   3. Go to Configuration → Configure Admin API scopes → select permissions → Save
#   4. Go to API credentials → Install app → Reveal token once
#   5. Copy the token below (starts with shpat_)
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTION B — Advanced: OAuth Client Credentials (enables auto token refresh)
# Only use this if you have a Shopify app with OAuth set up.
# Leave both blank if you are using Option A.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# ----------------------------------------------------------
# OPTIONAL: Shopify API version
# Default is 2024-10. Only change if you need a specific version.
# ----------------------------------------------------------
SHOPIFY_API_VERSION=2025-01

# ----------------------------------------------------------
# OPTIONAL: Security tuning
# BEARER_TOKEN          — Token clients must send (Authorization: Bearer <token>)
# ALLOW_TOKEN_QUERY_PARAM — Set to 1 only if your MCP client cannot send headers
# MAX_REQUEST_BODY      — Max incoming body size in bytes (default: 1048576 = 1 MB)
# RATE_LIMIT_RPM        — Max requests per minute per IP (default: 60)
# RATE_LIMIT_MAX_IPS    — Max IPs tracked by rate limiter (default: 10000)
# TRUSTED_PROXY_COUNT   — How many reverse proxies sit in front (default: 1)
# ----------------------------------------------------------
BEARER_TOKEN=
ALLOW_TOKEN_QUERY_PARAM=
MAX_REQUEST_BODY=1048576
RATE_LIMIT_RPM=60
RATE_LIMIT_MAX_IPS=10000
TRUSTED_PROXY_COUNT=1

# ----------------------------------------------------------
# OPTIONAL: Server configuration
# PORT          — The port the MCP server runs on (default: 8000)
# MCP_TRANSPORT — Keep as streamable-http for use with Claude.ai
# ----------------------------------------------------------
PORT=8000
MCP_TRANSPORT=streamable-http
